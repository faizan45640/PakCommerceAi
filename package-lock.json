      "resolved": "apps/web",
      "link": true
    },
    "packages/ai": {
      "name": "@pakcommerce/ai",
      "version": "0.1.0"
    },
    "packages/integrations": {
      "name": "@pakcommerce/integrations",
      "version": "0.1.0"
    },
